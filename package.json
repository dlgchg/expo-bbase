{
  "name": "expo-bbase",
  "version": "1.0.3",
  "description": "Expo SDK 54+ scaffolding CLI with interactive module selection for React Native projects",
  "bin": {
    "expo-bbase": "bin/cli.js"
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "prompts": "^2.4.2",
    "chalk": "^5.3.0",
    "ora": "^8.0.0",
    "fs-extra": "^11.2.0",
    "execa": "^9.0.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "tsup": "^8.0.0",
    "@types/fs-extra": "^11.0.0",
    "@types/prompts": "^2.4.0"
  },
  "keywords": [
    "expo",
    "react-native",
    "cli",
    "scaffold",
    "boilerplate",
    "expo-sdk54",
    "nativewind",
    "expo-router",
    "zustand",
    "tanstack-query"
  ],
  "author": "curmido",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dlgchg/expo-bbase.git"
  },
  "homepage": "https://github.com/dlgchg/expo-bbase#readme",
  "bugs": {
    "url": "https://github.com/dlgchg/expo-bbase/issues"
  }
